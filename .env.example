# Frontend Environment Variables (Production - Vercel)
# 
# Set these in your Vercel project:
# 1. Go to: https://vercel.com/dashboard
# 2. Select your project → Settings → Environment Variables
# 3. Add the following variables:

# API Base URL - Your Render backend URL
VITE_API_BASE_URL=https://nextgen-residency.onrender.com

# Google reCAPTCHA v2 Site Key (public)
# Get from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=your_production_site_key_here

